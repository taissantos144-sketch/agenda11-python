from colorama import Fore, Style, init
init()

niveis = [
    "Nível 1 = Muito baixo (crítico)",
    "Nível 2 = Baixo",
     "Nível 3 = Médio",
     "Nível 4 = Alto",
     "Nível 5 = Muito alto (alerta)"
]

def definir_cor(nivel):
    if nivel == 1:
        return Fore.RED
    elif nivel == 2:
        return Fore.YELLOW
    elif nivel == 3:
        return Fore.GREEN
    elif nivel == 4:
        return Fore.CYAN
    elif nivel == 5:
        return Fore.BLUE
    else:
        return Style.RESET_ALL
print("Controle de nível do reservatório\n")
for i in range(5):
        cor = definir_cor(i + 1)
        print(cor + niveis[i] + Style.RESET_ALL)